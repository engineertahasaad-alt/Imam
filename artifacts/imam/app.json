{
  "expo": {
    "name": "Imam",
    "slug": "imam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "imam",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7713872d-666f-4b98-af99-27f793bf7172",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0d1321"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.imam.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to calculate accurate prayer times for your location.",
        "NSLocationAlwaysUsageDescription": "Used to calculate accurate prayer times for your location.",
        "NSMotionUsageDescription": "Used to detect prayer movements using motion sensors.",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.imam.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d1321"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_EXACT_ALARM",
        "SCHEDULE_EXACT_ALARM",
        "MODIFY_AUDIO_SETTINGS",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "POST_NOTIFICATIONS",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "./plugins/withAdhanAlarm",
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialCommunityIcons.ttf",
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Feather.ttf",
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialIcons.ttf"
          ]
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#34d399",
          "sounds": [
            "./assets/audio/azan1.mp3",
            "./assets/audio/azan2.mp3",
            "./assets/audio/azan3.mp3",
            "./assets/audio/azan4.mp3",
            "./assets/audio/azan5.mp3",
            "./assets/audio/azan6.mp3",
            "./assets/audio/azan7.mp3",
            "./assets/audio/azan8.mp3"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Imam needs your location to calculate accurate prayer times.",
          "locationWhenInUsePermission": "Imam needs your location to calculate accurate prayer times."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "7713872d-666f-4b98-af99-27f793bf7172"
      }
    }
  }
}
